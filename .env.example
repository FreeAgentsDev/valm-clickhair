# ─── Base de datos (OBLIGATORIO) ───
# NUNCA commitear credenciales reales. Este archivo es solo ejemplo.
DATABASE_URL=postgresql://user:password@host:port/database

# ─── Mercado Pago (OBLIGATORIO si se acepta pago con MP) ───
# Access token: https://www.mercadopago.com.co/developers/panel/app
MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_access_token
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=your_mercado_pago_public_key
# Secret para validar firma de webhooks. OBLIGATORIO: sin esto, los webhooks
# son rechazados. Configúralo en el panel de MP y copia aquí.
MERCADO_PAGO_WEBHOOK_SECRET=your_mp_webhook_secret

# ─── ADDI (OBLIGATORIO si se acepta pago con ADDI) ───
ADDI_CLIENT_ID=your_addi_client_id
ADDI_CLIENT_SECRET=your_addi_client_secret
ADDI_ENV=staging  # o "production"
# Secret compartido para validar callbacks. OBLIGATORIO: se envía en el
# callbackUrl y se verifica en el endpoint. Generar uno aleatorio de 32+ chars.
ADDI_CALLBACK_SECRET=generate_random_secret_min_32_chars

# ─── Admin Panel (OBLIGATORIO) ───
# ADMIN_PASSWORD: mínimo 12 caracteres. Fuerte (mezcla de mayús/minús/números/símbolos).
# ADMIN_SECRET: mínimo 32 caracteres aleatorios. Se usa para firmar sesiones.
# La app FALLA al iniciar si estos no cumplen los requisitos.
ADMIN_PASSWORD=your_secure_password_here_min_12_chars
ADMIN_SECRET=your_random_secret_here_min_32_characters

# ─── URL base (OBLIGATORIO en producción) ───
# Usada para construir URLs de webhooks y redirects.
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# ─── Cloudflare R2 (para subida de imágenes) ───
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Wompi (opcional) ───
WOMPI_API_KEY=your_wompi_api_key
WOMPI_USER_PRINCIPAL_ID=your_wompi_principal_id
WOMPI_ACCEPTANCE_TOKEN=your_wompi_acceptance_token

# ─── Skydropx (opcional, para cotización de envíos externa) ───
SKYDROPX_TOKEN=your_skydropx_token

# ─── Información legal de la empresa ───
COMPANY_LEGAL_NAME="Valm Beauty S.A.S."
COMPANY_NIT="000000000-0"
COMPANY_ADDRESS="Cra 23A # 60-11, Manizales, Caldas, Colombia"
COMPANY_PHONE="310 407 7106"
COMPANY_CONTACT_EMAIL="contacto@valmbeauty.com"
POLICY_EFFECTIVE_DATE="2026-04-14"
